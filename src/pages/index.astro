---
import Layout from "../layouts/Layout.astro";
import BigSponsors from "./big-sponsors.astro";
---

<Layout title="coolLabs">
  <h1 class="text-3xl font-bold tracking-tight text-white md:text-6xl px-4">
    Software without compromise<span class="text-warning">.</span>
  </h1>
  <h2 class="text-base pt-2 text-neutral-400 px-4">
    Free, open source, and built for you. <i class="ph-duotone ph-heart text-pink-500 text-xl inline-block -mt-0.5" aria-hidden="true"></i>
  </h2>
  <div class="pb-10 pt-3 flex justify-center">
    <a
      class="text-white hover:underline flex gap-2 items-center text-xs transition-colors"
      target="_blank"
      href="https://twitch.tv/heyandras"
    >
      <i class="ph-duotone ph-twitch-logo text-purple-500 text-base" aria-hidden="true"></i>
      Building them in live-streams</a
    >
  </div>

  <div class="max-w-3xl mx-auto w-full px-4 text-left">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pb-8">
      <a
        href="https://coolify.io?ref=coollabs"
        class="group block p-5 rounded-xl bg-coolgray-200 border border-coolgray-400 hover:border-[oklch(87.90%_0.1533_91.61/0.4)] transition-colors"
      >
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <h3
            class="text-xl font-bold text-white group-hover:text-warning transition-colors"
          >
            Coolify
          </h3>
          <i class="ph-duotone ph-arrow-up-right text-neutral-600 group-hover:text-warning transition-colors flex-shrink-0 text-base translate-y-0.5" aria-hidden="true"></i>
        </div>
        <p class="text-sm text-neutral-400 mb-2">
          Self-hosting with superpowers. An open-source & self-hostable Heroku /
          Netlify / Vercel alternative.
        </p>
        <span class="text-xs text-neutral-500">
          <span class="text-warning opacity-80">Thousands</span> of cloud users &middot; <span
            class="text-warning opacity-80">hundreds of thousands</span
          > of self-hosted instances
        </span>
      </a>

      <a
        href="https://jean.build?ref=coollabs"
        class="group block p-5 rounded-xl bg-coolgray-200 border border-coolgray-400 hover:border-[oklch(87.90%_0.1533_91.61/0.4)] transition-colors"
      >
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <div class="flex items-center gap-2">
            <h3
              class="text-xl font-bold text-white group-hover:text-warning transition-colors"
            >
              Jean
            </h3>
            <span
              class="text-[10px] font-semibold uppercase tracking-wider bg-[oklch(87.90%_0.1533_91.61/0.15)] text-warning px-2 py-0.5 rounded-full"
              >New</span
            >
          </div>
          <i class="ph-duotone ph-arrow-up-right text-neutral-600 group-hover:text-warning transition-colors flex-shrink-0 text-base translate-y-0.5" aria-hidden="true"></i>
        </div>
        <p class="text-sm text-neutral-400 mb-2">
          A dev environment for AI agents. Run AI agents in parallel, in isolated
          workspaces with Claude Code, Codex & OpenCode. Open source and free forever.
        </p>
      </a>

      <a
        href="https://serverlesshorrors.com?ref=coollabs"
        class="group block p-5 rounded-xl bg-coolgray-200 border border-coolgray-400 hover:border-[oklch(87.90%_0.1533_91.61/0.4)] transition-colors"
      >
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <h3
            class="text-xl font-bold text-white group-hover:text-warning transition-colors"
          >
            Serverless Horrors
          </h3>
          <i class="ph-duotone ph-arrow-up-right text-neutral-600 group-hover:text-warning transition-colors flex-shrink-0 text-base translate-y-0.5" aria-hidden="true"></i>
        </div>
        <p class="text-sm text-neutral-400">
          A simple blog where you can read all the horror stories of serverless.
        </p>
      </a>

      <a
        href="https://fonts.coollabs.io?ref=coollabs"
        class="group block p-5 rounded-xl bg-coolgray-200 border border-coolgray-400 hover:border-[oklch(87.90%_0.1533_91.61/0.4)] transition-colors"
      >
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <h3
            class="text-xl font-bold text-white group-hover:text-warning transition-colors"
          >
            Fonts
          </h3>
          <i class="ph-duotone ph-arrow-up-right text-neutral-600 group-hover:text-warning transition-colors flex-shrink-0 text-base translate-y-0.5" aria-hidden="true"></i>
        </div>
        <p class="text-sm text-neutral-400 mb-2">
          A privacy-friendly drop-in replacement for Google Fonts.
        </p>
        <span class="text-xs text-neutral-500">
          <span class="text-warning opacity-80">{(7).toLocaleString()}+</span> million requests
          per month
        </span>
      </a>
      <a
        href="https://llmhorrors.com?ref=coollabs"
        class="group block p-5 rounded-xl bg-coolgray-200 border border-coolgray-400 hover:border-[oklch(87.90%_0.1533_91.61/0.4)] transition-colors"
      >
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <h3
            class="text-xl font-bold text-white group-hover:text-warning transition-colors"
          >
            LLM Horrors
          </h3>
          <i class="ph-duotone ph-arrow-up-right text-neutral-600 group-hover:text-warning transition-colors flex-shrink-0 text-base translate-y-0.5" aria-hidden="true"></i>
        </div>
        <p class="text-sm text-neutral-400">
          A simple blog where you can read all the horror stories of LLMs.
        </p>
      </a>
    </div>
  </div>

  <script>
    fetch("https://raw.githubusercontent.com/coollabsio/coollabs-cdn/main/json/business.json")
      .then((res) => res.json())
      .then((data) => {
        const cloudUsersEl = document.getElementById("cloud-users");
        if (cloudUsersEl && data["coolify-cloud-users"]) {
          cloudUsersEl.textContent =
            data["coolify-cloud-users"].toLocaleString();
        }
      })
      .catch(() => {
        const cloudUsersEl = document.getElementById("cloud-users");
        if (cloudUsersEl) {
          cloudUsersEl.textContent = "2,800";
        }
      });
  </script>
</Layout>
