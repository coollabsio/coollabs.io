---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us | coolLabs">
  <h1 class="text-3xl font-bold tracking-tight text-white md:text-6xl px-4">
    Contact Us<span class="text-warning">.</span>
  </h1>
  <h2 class="text-base pb-10 pt-2 text-neutral-400 px-4">
    We'd love to hear from you.
  </h2>

  <div class="pt-4 max-w-2xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <button
        id="copy-email"
        class="bg-coolgray-200 rounded-xl p-8 border border-coolgray-400 hover:border-warning transition-colors flex flex-col items-center gap-4 text-center cursor-pointer w-full"
      >
        <svg
          class="h-10 w-10 text-warning"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
          ></path>
        </svg>
        <div>
          <div class="text-lg font-semibold text-white">Email</div>
          <div id="email-text" class="text-neutral-400 mt-1">hi[at]coollabs.io</div>
        </div>
      </button>

      <a
        href="https://coollabs.io/discord"
        target="_blank"
        class="bg-coolgray-200 rounded-xl p-8 border border-coolgray-400 hover:border-warning transition-colors flex flex-col items-center gap-4 text-center"
      >
        <svg
          class="h-10 w-10 text-warning"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127a12.299 12.299 0 0 1-1.873.892a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.956-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.946 2.418-2.157 2.418z"
          ></path>
        </svg>
        <div>
          <div class="text-lg font-semibold text-white">Discord</div>
          <div class="text-neutral-400 mt-1">Join our 20k+ community</div>
        </div>
      </a>
    </div>
  </div>
  <script>
    document.getElementById("copy-email")?.addEventListener("click", () => {
      navigator.clipboard.writeText("hi@coollabs.io").then(() => {
        const el = document.getElementById("email-text");
        if (el) {
          const original = el.textContent;
          el.textContent = "Copied to clipboard!";
          el.classList.remove("text-neutral-400");
          el.classList.add("text-warning");
          setTimeout(() => {
            el.textContent = original;
            el.classList.remove("text-warning");
            el.classList.add("text-neutral-400");
          }, 2000);
        }
      });
    });
  </script>
</Layout>
